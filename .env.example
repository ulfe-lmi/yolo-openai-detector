# Fixed local bearer token for the detector gateway.
# Replace in local/private .env only. Do not commit real secrets.
YOLO_GATEWAY_API_KEY=local-dev-key

# CPU-only defaults.
YOLO_MODEL_ID=yolo-cpu-detector
YOLO_DEVICE=cpu
YOLO_MAX_IMAGE_BYTES=5242880
YOLO_MAX_IMAGE_PIXELS=12000000
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_IMAGE_SIZE=640
